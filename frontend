        function postData(url, data) {
            return fetch(url, {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: new URLSearchParams(data)
            });
        }

        function escapeHtml(text) {
            const div = document.createElement("div");
            div.textContent = text;
            return div.innerHTML;
        }

        function renderViewer(title, meta, lines) {
            const viewer = document.getElementById("viewer");
            let html = "<h3>" + escapeHtml(title) + "</h3>";
            html += "<div class='viewer-meta'>" + escapeHtml(meta) + "</div>";
            for (const line of lines) {
                html += "<div class='viewer-line'>" + escapeHtml(line) + "</div>";
            }
            viewer.innerHTML = html;
        }

        function openDummyFile(filename) {
            const item = FILE_DATA[filename];
            if (!item) return;
            postData("/open", { file: filename });
            postData("/track", { action: "Opened file preview: " + filename });
            const meta = item.type + " • " + item.owner + " • Updated " + item.updated;
            renderViewer(item.title, meta, item.content);
            setTimeout(() => { postData("/close", { file: filename }); }, 1500);
        }

        function showActionDetails(actionName) {
            const item = ACTION_DATA[actionName];
            if (!item) return;
            postData("/track", { action: actionName });
            renderViewer(item.title, "Banking action details", item.details);
        }

        function trackOnly(actionName) {
            postData("/track", { action: actionName });
            renderViewer("Settlement Rail", "Interaction recorded", [
                "The requested banking console interaction was recorded.",
                "No additional ledger artifact is attached to this action."
            ]);
        }

        function sendChat() {
            const input = document.getElementById("msg");
            const msg = input.value.trim();
            if (!msg) return;
            postData("/chatbot", { message: msg })
                .then(res => res.json())
                .then(data => {
                    const chatbox = document.getElementById("chatbox");
                    chatbox.innerHTML += "<div class='chat-msg'><span class='you'>You:</span> " + escapeHtml(msg) + "</div>";
                    chatbox.innerHTML += "<div class='chat-msg'><span class='bot'>Bank OS:</span> " + escapeHtml(data.response) + "</div>";
                    chatbox.scrollTop = chatbox.scrollHeight;
                    input.value = "";
                });
        }

        document.getElementById("msg").addEventListener("keydown", function(event) {
            if (event.key === "Enter") { sendChat(); }
        });
    </script>
</body>
</html>
